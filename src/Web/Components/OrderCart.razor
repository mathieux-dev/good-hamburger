@* OrderCart.razor — comanda lateral com totais reativos *@

<div class="cart">
    <header class="cart-head">
        <div>
            <div class="mono tiny muted">COMANDA Nº</div>
            <div class="display-md">@(EditingId ?? "#1043")</div>
        </div>
        <div class="right">
            <div class="mono tiny muted">@DateTime.Now.ToString("dd/MM/yyyy")</div>
            <div class="mono tiny muted">@DateTime.Now.ToString("HH:mm")</div>
        </div>
    </header>

    @* Seletor de tipo de serviço *@
    <div class="service-type-row">
        @foreach (var type in new[] { ("🪑", "Salão"), ("🥡", "Retirada"), ("🛵", "Delivery") })
        {
            <button class="service-btn @(_serviceType == type.Item2 ? "active" : "")"
                    @onclick="() => _serviceType = type.Item2">
                <span>@type.Item1</span>
                <span class="service-label">@type.Item2</span>
            </button>
        }
    </div>

    <div class="field">
        <label>@CustomerLabel</label>
        <input class="mono dashed-input"
               @bind="_customer" @bind:event="oninput"
               placeholder="@CustomerPlaceholder" />
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="error-banner">
            <span class="icon">⚠</span>
            <div>
                <div class="condensed tiny upper">Item Duplicado</div>
                <div>@Error</div>
            </div>
            <button @onclick="() => OnDismissError.InvokeAsync()">×</button>
        </div>
    }

    <div class="cart-items">
        @if (!Items.Any())
        {
            <div class="empty-cart">
                <div class="display-sm">COMANDA VAZIA</div>
                <div class="mono tiny">Toque em um item para começar</div>
            </div>
        }
        else
        {
            @foreach (var item in Items)
            {
                <div class="cart-row" @key="item.Id">
                    <div class="cart-thumb">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" style="width:32px;height:32px;object-fit:cover;border-radius:4px;" />
                        }
                        else
                        {
                            <FoodIcon Kind="@item.Placeholder" Size="32" />
                        }
                    </div>
                    <div class="cart-info">
                        <div class="display-sm">@item.Name</div>
                        <div class="mono tiny muted upper">@item.Category.Label()</div>
                    </div>
                    <div class="mono">@item.Price.ToString("C")</div>
                    <button class="remove-dot" @onclick="() => OnRemove.InvokeAsync(item)">×</button>
                </div>
            }
        }
    </div>

    @if (Items.Any())
    {
        <div class="field">
            <label>Observação</label>
            <textarea class="mono note-input"
                      @bind="_note" @bind:event="oninput"
                      placeholder="Sem cebola, ponto da carne..."></textarea>
        </div>

        <div class="dash"></div>
        <div class="totals mono">
            <div class="row">
                <span>Subtotal</span>
                <span>@_summary.Subtotal.ToString("C")</span>
            </div>
            @if (_summary.Rule is not null)
            {
                <div class="row discount">
                    <span>Desconto · @_summary.Rule.Label</span>
                    <span>- @_summary.Discount.ToString("C")</span>
                </div>
                <div class="discount-note">
                    @((_summary.Rule.Rate * 100).ToString("0"))% OFF APLICADO
                </div>
            }
        </div>
        <div class="total-box">
            <span class="display-sm">TOTAL</span>
            <span class="display-lg red">@_summary.Total.ToString("C")</span>
        </div>
    }

    <button class="btn btn-green btn-lg full"
            disabled="@(!Items.Any())"
            @onclick="() => OnSubmit.InvokeAsync()">
        @(string.IsNullOrEmpty(EditingId) ? "🍔 Enviar pedido" : "💾 Salvar alterações")
    </button>
</div>

@code {
    [Parameter] public List<MenuItemDto> Items { get; set; } = new();
    [Parameter] public string Customer { get; set; } = "";
    [Parameter] public EventCallback<string> CustomerChanged { get; set; }
    [Parameter] public string Note { get; set; } = "";
    [Parameter] public EventCallback<string> NoteChanged { get; set; }
    [Parameter] public string ServiceType { get; set; } = "Salão";
    [Parameter] public EventCallback<string> ServiceTypeChanged { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback OnDismissError { get; set; }
    [Parameter] public EventCallback<MenuItemDto> OnRemove { get; set; }
    [Parameter] public EventCallback OnSubmit { get; set; }
    [Parameter] public string? EditingId { get; set; }

    private DiscountCalculator.Summary _summary = new(0, null, 0, 0);

    private string _serviceType
    {
        get => ServiceType;
        set { ServiceType = value; ServiceTypeChanged.InvokeAsync(value); }
    }

    private string _customer
    {
        get => Customer;
        set { Customer = value; CustomerChanged.InvokeAsync(value); }
    }
    private string _note
    {
        get => Note;
        set { Note = value; NoteChanged.InvokeAsync(value); }
    }

    private string CustomerLabel => ServiceType switch
    {
        "Retirada" => "Nome do cliente",
        "Delivery" => "Endereço de entrega",
        _          => "Mesa / Comanda"
    };

    private string CustomerPlaceholder => ServiceType switch
    {
        "Retirada" => "Ex: João Silva",
        "Delivery" => "Ex: Rua das Flores, 123",
        _          => "Ex: Mesa 01, Balcão"
    };

    protected override void OnParametersSet()
    {
        _summary = DiscountCalculator.Summarize(Items);
    }
}
